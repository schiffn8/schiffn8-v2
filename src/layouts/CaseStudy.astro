---
import Base from './Base.astro';
import SpecBlock from '../components/SpecBlock.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, role, year, client, tags, hero } = project.data;

const specRows = [
  { label: 'Role', value: role },
  { label: 'Year', value: String(year) },
  ...(client ? [{ label: 'Client', value: client }] : []),
  { label: 'Category', value: tags.join(', ') },
];
---

<Base title={title} description={summary}>
  <article class="case-study">

    <!-- Header: title → summary → spec block (no hero image yet) -->
    <header class="case-study__header">
      <p class="case-study__kicker label">
        {tags[0]}
      </p>
      <h1 class="case-study__title font-display">
        {title}
      </h1>
      <p class="case-study__summary">
        {summary}
      </p>
      <div class="case-study__spec">
        <SpecBlock rows={specRows} />
      </div>
    </header>

    <!-- Hero: full-bleed, mask-reveals in motion-patterns skill -->
    <div class="case-study__hero">
      <Image
        src={hero}
        alt={`${title} — hero`}
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        class="case-study__hero-img"
      />
    </div>

    <!-- Body prose -->
    <div class="case-study__body prose">
      <slot />
    </div>

  </article>
</Base>

<style>
  .case-study__header {
    padding: var(--space-32) var(--gutter) var(--space-16);
    max-width: var(--max-w-wide);
    margin: 0 auto;
  }

  .case-study__kicker {
    margin-bottom: var(--space-6);
  }

  .case-study__title {
    font-size: var(--text-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
    max-width: 18ch;
  }

  .case-study__summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--muted);
    max-width: 52ch;
    margin-bottom: var(--space-12);
  }

  .case-study__spec {
    max-width: 480px;
  }

  .case-study__hero {
    overflow: hidden;
    margin-bottom: var(--space-24);
  }

  .case-study__hero-img {
    width: 100%;
    height: 70vh;
    object-fit: cover;
    border-radius: 0;
  }

  .case-study__body {
    max-width: var(--max-w-prose);
    margin: 0 auto;
    padding: 0 var(--gutter) var(--space-32);
  }

  /* Prose typography */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-display);
    margin-top: var(--space-24);
    margin-bottom: var(--space-8);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-heading);
    margin-top: var(--space-16);
    margin-bottom: var(--space-6);
  }

  .prose :global(p) {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
    color: var(--ink);
  }

  .prose :global(p + p) {
    margin-top: var(--space-4);
  }
</style>
