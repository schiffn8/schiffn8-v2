---
import Base from './Base.astro';
import SpecBlock from '../components/SpecBlock.astro';
import MaskReveal from '../components/MaskReveal.astro';
import VideoScrub from '../components/interactive/VideoScrub';
import { Image, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, role, year, client, tags, hero, heroVideo } = project.data;

const specRows = [
  { label: 'Role',     value: role },
  { label: 'Year',     value: String(year) },
  ...(client ? [{ label: 'Client', value: client }] : []),
  { label: 'Category', value: tags.join(', ') },
];

// Optimized poster for video scrub fallback
const posterImg = heroVideo
  ? await getImage({ src: hero, width: 1600, format: 'webp' })
  : null;

// OG image — full URL for social sharing
const ogImage = Astro.site
  ? new URL(hero.src, Astro.site).toString()
  : hero.src;

// Slug used for view-transition-name (must be a valid CSS ident)
const transitionName = `project-${project.id.replace(/[^a-z0-9]/gi, '-')}`;

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description: summary,
  creator: { '@type': 'Person', name: 'Nate Schiffler', url: 'https://schiffn8design.com' },
  datePublished: `${year}-01-01`,
  image: ogImage,
};
---

<Base title={title} description={summary} ogImage={ogImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="case-study">

    <!-- Header: kicker → title → summary → spec block -->
    <header class="case-study__header">
      <p class="case-study__kicker label">
        {tags[0]}
      </p>
      <h1 class="case-study__title font-display">
        {title}
      </h1>
      <p class="case-study__summary">
        {summary}
      </p>
      <div class="case-study__spec">
        <SpecBlock rows={specRows} />
      </div>
    </header>

    <!-- Hero: video scrub OR static image with view-transition-name -->
    {heroVideo ? (
      <div
        class="case-study__hero-video"
        transition:name={transitionName}
      >
        <VideoScrub
          client:load
          src={heroVideo}
          poster={posterImg?.src}
          scrollHeightVh={300}
        />
      </div>
    ) : (
      <div
        class="case-study__hero"
        transition:name={transitionName}
      >
        <MaskReveal>
          <Image
            src={hero}
            alt={`${title} — hero`}
            widths={[800, 1200, 1600, 2000]}
            sizes="100vw"
            class="case-study__hero-img"
          />
        </MaskReveal>
      </div>
    )}

    <!-- Body prose -->
    <div class="case-study__body prose">
      <slot />
    </div>

  </article>
</Base>

<style>
  .case-study__header {
    padding: var(--space-32) var(--gutter) var(--space-16);
    max-width: var(--max-w-wide);
    margin: 0 auto;
  }

  .case-study__kicker {
    margin-bottom: var(--space-6);
    display: block;
  }

  .case-study__title {
    font-size: var(--text-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
    max-width: 18ch;
  }

  .case-study__summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--muted);
    max-width: 52ch;
    margin-bottom: var(--space-12);
  }

  .case-study__spec {
    max-width: 480px;
  }

  /* Static hero */
  .case-study__hero {
    overflow: hidden;
    margin-bottom: var(--space-24);
  }

  .case-study__hero-img {
    width: 100%;
    height: 70vh;
    object-fit: cover;
    border-radius: 0;
  }

  /* Video scrub — no overflow clip, container must breathe */
  .case-study__hero-video {
    margin-bottom: var(--space-24);
  }

  /* Prose */
  .case-study__body {
    max-width: var(--max-w-prose);
    margin: 0 auto;
    padding: 0 var(--gutter) var(--space-32);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-display);
    margin-top: var(--space-24);
    margin-bottom: var(--space-8);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-heading);
    margin-top: var(--space-16);
    margin-bottom: var(--space-6);
  }

  .prose :global(p) {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
    color: var(--ink);
  }

  .prose :global(p + p) {
    margin-top: var(--space-4);
  }

  /* Figure / Gallery components inside prose */
  .prose :global(.figure),
  .prose :global(.gallery) {
    max-width: none;
  }
</style>
