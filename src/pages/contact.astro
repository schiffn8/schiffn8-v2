---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Nate Schiffler — open to new work in the Twin Cities and remotely.">
  <section class="contact">
    <div class="contact__inner">

      <h1 class="contact__headline font-display">Open to new work.</h1>

      <div class="contact__grid">
        <div class="contact__primary">
          <a href="mailto:hello@schiffn8design.com" class="contact__email font-display">
            hello@schiffn8design.com
          </a>
          <p class="contact__location label">
            Based in Bloomington, MN.<br />
            Available remotely or in the Twin Cities.
          </p>
        </div>

        <nav class="contact__links" aria-label="Contact links">
          <ul class="font-mono">
            <li><a href="https://linkedin.com/in/nateschiffler" target="_blank" rel="noopener" class="contact__link">LinkedIn →</a></li>
            <li><a href="/resume.pdf" class="contact__link">Resume →</a></li>
          </ul>
        </nav>
      </div>

    </div>
  </section>
</Base>

<style>
  .contact {
    min-height: 80dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-32) var(--gutter);
  }

  .contact__inner {
    max-width: var(--max-w-wide);
    margin: 0 auto;
    width: 100%;
  }

  .contact__headline {
    font-size: var(--text-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-16);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
    border-top: 1px solid var(--line);
    padding-top: var(--space-8);
  }

  .contact__email {
    display: block;
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-heading);
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-color: var(--accent);
    margin-bottom: var(--space-6);
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .contact__email:hover { opacity: 0.7; }

  .contact__location {
    color: var(--muted);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  .contact__links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact__link {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .contact__link:hover { color: var(--ink); }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
