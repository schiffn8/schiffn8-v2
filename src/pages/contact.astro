---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Nate Schiffler — open to new work in the Twin Cities and remotely.">
  <section style="padding: var(--space-xl) var(--space-md); min-height: 80vh; display: flex; flex-direction: column; justify-content: center;">
    <div style="max-width: 1200px; margin: 0 auto; width: 100%;">
      <h1 class="font-display" style="font-size: clamp(3.5rem, 9vw, 8rem); margin: 0 0 var(--space-lg); line-height: 1.0; letter-spacing: -0.03em;">
        Open to new work.
      </h1>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); align-items: start;">
        <div>
          <a
            href="mailto:hello@schiffn8design.com"
            class="font-display"
            style="font-size: clamp(1.25rem, 3vw, 2rem); text-decoration: underline; text-underline-offset: 6px; text-decoration-color: var(--color-accent);"
          >
            hello@schiffn8design.com
          </a>
          <p class="font-mono text-muted" style="font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; margin-top: 1rem;">
            Based in Bloomington, MN.<br />
            Available remotely or in the Twin Cities.
          </p>
        </div>

        <nav aria-label="Contact links">
          <ul class="font-mono" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase;">
            <li>
              <a href="https://linkedin.com/in/nateschiffler" target="_blank" rel="noopener" style="color: var(--color-muted); transition: color var(--transition-base);">
                LinkedIn →
              </a>
            </li>
            <li>
              <a href="/resume.pdf" style="color: var(--color-muted); transition: color var(--transition-base);">
                Resume →
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </section>
</Base>
