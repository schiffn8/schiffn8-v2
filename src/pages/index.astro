---
import Base from '../layouts/Base.astro';
import Hero from '../components/interactive/Hero';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featured = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<Base title="Home">
  <Hero
    client:load
    headline="Design systems for teams shipping real things."
    subline="Brand, product, and motion — built to function intelligently."
  />

  {featured.length > 0 && (
    <section style="padding: var(--space-xl) var(--space-md);">
      <div style="max-width: 1200px; margin: 0 auto;">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-lg);">
          <h2 class="font-mono text-muted" style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin: 0;">
            Selected Work
          </h2>
          <a href="/work" class="font-mono text-muted" style="font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; transition: color var(--transition-base);">
            All Work →
          </a>
        </div>
        <ProjectGrid projects={featured} />
      </div>
    </section>
  )}

  <section style="padding: var(--space-xl) var(--space-md); border-top: 1px solid var(--color-border);">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg);">
      <div>
        <p style="line-height: 1.7; margin-bottom: 1.5rem;">
          I build cohesive visual identities, strategic brand systems, and high-impact digital
          experiences that translate complex ideas into clear, compelling narratives.
        </p>
        <p style="line-height: 1.7; color: var(--color-muted);">
          My work blends creative direction with technical execution, integrating AI-driven
          workflows to accelerate ideation, expand visual range, and modernize production.
        </p>
      </div>
      <dl class="font-mono" style="font-size: 0.75rem; display: grid; grid-template-columns: max-content 1fr; gap: 0.75rem 2rem; align-content: start;">
        <dt style="text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted);">Brand</dt>
        <dd style="color: var(--color-ink);">Identity systems, campaigns</dd>
        <dt style="text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted);">Product</dt>
        <dd style="color: var(--color-ink);">UI/UX, motion, prototyping</dd>
        <dt style="text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted);">AI-Assisted</dt>
        <dd style="color: var(--color-ink);">Workflow integration, asset generation</dd>
        <dt style="text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted);">Physical</dt>
        <dd style="color: var(--color-ink);">Exhibition, packaging, apparel</dd>
      </dl>
    </div>
  </section>

  <section style="padding: var(--space-xl) var(--space-md); border-top: 1px solid var(--color-border);">
    <div style="max-width: 1200px; margin: 0 auto; text-align: center;">
      <p class="font-display" style="font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: -0.02em; margin-bottom: 2rem;">
        Open to new work.
      </p>
      <div class="font-mono" style="display: flex; gap: 2rem; justify-content: center; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted);">
        <a href="mailto:hello@schiffn8design.com">Email</a>
        <a href="https://linkedin.com/in/nateschiffler" target="_blank" rel="noopener">LinkedIn</a>
        <a href="/contact">Contact →</a>
      </div>
    </div>
  </section>
</Base>
