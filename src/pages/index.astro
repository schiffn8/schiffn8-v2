---
import Base from '../layouts/Base.astro';
import Hero from '../components/interactive/Hero';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featured = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<Base title="Home">

  <!-- Section 1: Hero (100vh) -->
  <Hero
    client:load
    headline="Design systems for teams shipping real things."
    subline="Brand, product, and motion — built to function intelligently."
  />

  <!-- Section 2: Selected work grid -->
  {featured.length > 0 && (
    <section class="section-work">
      <div class="container">
        <div class="section-work__header">
          <h2 class="label">Selected Work</h2>
          <a href="/work" class="section-work__all label">All Work →</a>
        </div>
        <ProjectGrid projects={featured} />
      </div>
    </section>
  )}

  <!-- Section 3: Practice + capabilities -->
  <section class="section-about">
    <div class="container section-about__grid">
      <div class="section-about__bio">
        <p>
          I build cohesive visual identities, strategic brand systems, and high-impact digital
          experiences that translate complex ideas into clear, compelling narratives.
        </p>
        <p style="margin-top: var(--space-6); color: var(--muted);">
          My work blends creative direction with technical execution, integrating AI-driven
          workflows to accelerate ideation, expand visual range, and modernize production.
        </p>
      </div>
      <dl class="section-about__capabilities font-mono">
        <dt class="label">Brand</dt>
        <dd>Identity systems, campaigns</dd>
        <dt class="label">Product</dt>
        <dd>UI/UX, motion, prototyping</dd>
        <dt class="label">AI-Assisted</dt>
        <dd>Workflow integration, asset generation</dd>
        <dt class="label">Physical</dt>
        <dd>Exhibition, packaging, apparel</dd>
      </dl>
    </div>
  </section>

  <!-- Section 4: Contact -->
  <section class="section-contact">
    <div class="container">
      <p class="section-contact__headline font-display">Open to new work.</p>
      <div class="section-contact__links font-mono">
        <a href="mailto:hello@schiffn8design.com" class="section-contact__link">Email</a>
        <a href="https://linkedin.com/in/nateschiffler" target="_blank" rel="noopener" class="section-contact__link">LinkedIn</a>
        <a href="/contact" class="section-contact__link">Contact →</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .container {
    max-width: var(--max-w-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .section-work {
    padding: var(--space-32) 0;
    border-top: 1px solid var(--line);
  }

  .section-work__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-16);
  }

  .section-work__all {
    transition: color var(--dur-fast) var(--ease-out);
    color: var(--muted);
  }
  .section-work__all:hover { color: var(--ink); }

  .section-about {
    padding: var(--space-32) 0;
    border-top: 1px solid var(--line);
  }

  .section-about__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-32);
    align-items: start;
  }

  .section-about__bio p {
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  .section-about__capabilities {
    font-size: var(--text-xs);
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-3) var(--space-8);
    align-content: start;
  }

  .section-about__capabilities dd {
    color: var(--ink);
    font-size: var(--text-sm);
    font-family: var(--font-body);
    letter-spacing: 0;
  }

  .section-contact {
    padding: var(--space-32) 0;
    border-top: 1px solid var(--line);
  }

  .section-contact__headline {
    font-size: var(--text-3xl);
    letter-spacing: var(--tracking-display);
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .section-contact__links {
    display: flex;
    gap: var(--space-8);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
  }

  .section-contact__link {
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .section-contact__link:hover { color: var(--ink); }

  @media (max-width: 768px) {
    .section-about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-16);
    }
  }
</style>
