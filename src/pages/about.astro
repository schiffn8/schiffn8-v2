---
import Base from '../layouts/Base.astro';
import SpecBlock from '../components/SpecBlock.astro';
---

<Base title="About" description="Nate Schiffler — Creative Technologist & Graphic Designer based in Bloomington, MN.">
  <article class="about">

    <header class="about__header">
      <h1 class="about__name font-display">Hi, I'm Nate.</h1>
      <p class="about__title label">Creative Technologist & Graphic Designer</p>
    </header>

    <section class="about__bio">
      <div class="about__bio-text">
        <p>
          I build cohesive visual identities, strategic brand systems, and high-impact digital
          experiences that translate complex ideas into clear, compelling narratives. My work
          blends creative direction with technical execution, integrating AI-driven workflows
          to accelerate ideation, expand visual range, and modernize production processes.
        </p>
        <p>
          Based in Bloomington, MN. Available for freelance and full-time opportunities in the
          Twin Cities and remotely.
        </p>
      </div>
    </section>

    <section class="about__practice">
      <h2 class="label about__section-label">Practice</h2>
      <SpecBlock rows={[
        { label: 'Brand',       value: 'Identity, campaigns, visual systems' },
        { label: 'Product',     value: 'UI/UX, prototyping, motion' },
        { label: 'Physical',    value: 'Packaging, exhibition, apparel' },
        { label: 'AI-Assisted', value: 'Image gen, video gen, workflow integration' },
      ]} />
    </section>

    <section class="about__stack">
      <h2 class="label about__section-label">Creative Stack</h2>
      <SpecBlock rows={[
        { label: 'Design', value: 'Figma, Illustrator, InDesign, Photoshop' },
        { label: '3D',     value: 'Cinema 4D, Blender' },
        { label: 'Motion', value: 'After Effects, Premiere' },
        { label: 'AI',     value: 'Midjourney, Runway, ComfyUI, ChatGPT' },
        { label: 'Code',   value: 'HTML/CSS/JS, Git' },
      ]} />
    </section>

    <section class="about__now">
      <h2 class="label about__section-label">Now</h2>
      <p>
        Currently exploring AI-native design workflows and how they change the economics of
        creative production.
      </p>
    </section>

  </article>
</Base>

<style>
  .about {
    max-width: var(--max-w-wide);
    margin: 0 auto;
    padding: 0 var(--gutter) var(--space-32);
  }

  .about__header {
    padding-top: var(--space-32);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--line);
    margin-bottom: var(--space-24);
  }

  .about__name {
    font-size: var(--text-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }

  .about__title {
    color: var(--muted);
  }

  .about__bio {
    margin-bottom: var(--space-24);
  }

  .about__bio-text p {
    line-height: var(--leading-relaxed);
    max-width: 55ch;
    margin-bottom: var(--space-6);
  }

  .about__practice,
  .about__stack,
  .about__now {
    margin-bottom: var(--space-24);
  }

  .about__section-label {
    margin-bottom: var(--space-6);
    display: block;
  }

  .about__now p {
    max-width: 55ch;
    line-height: var(--leading-relaxed);
  }
</style>
