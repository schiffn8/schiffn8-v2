---
import Base from '../../layouts/Base.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<Base title="Work" description="Selected projects by Nate Schiffler — brand, product, motion, and physical design.">
  <section class="work">
    <div class="work__inner">
      <header class="work__header">
        <p class="label work__kicker">Selected Work</p>
        <h1 class="work__title font-display">Projects</h1>
      </header>
      <ProjectGrid projects={projects} />
    </div>
  </section>
</Base>

<style>
  .work {
    padding: var(--space-32) 0;
  }

  .work__inner {
    max-width: var(--max-w-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .work__header {
    margin-bottom: var(--space-24);
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-8);
  }

  .work__kicker {
    margin-bottom: var(--space-4);
    display: block;
  }

  .work__title {
    font-size: var(--text-3xl);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-tight);
  }
</style>
