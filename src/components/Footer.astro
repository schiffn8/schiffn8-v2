---
const year = new Date().getFullYear();
---

<footer class="site-footer font-mono">
  <span>© {year} Nate Schiffler</span>
  <div class="site-footer__links">
    <a href="mailto:hello@schiffn8design.com" class="site-footer__link">Email</a>
    <a href="https://linkedin.com/in/nateschiffler" class="site-footer__link" target="_blank" rel="noopener">LinkedIn</a>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-8) var(--gutter);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-8);
  }

  .site-footer__link {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .site-footer__link:hover {
    color: var(--ink);
  }
</style>
