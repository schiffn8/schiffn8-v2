---
const year = new Date().getFullYear();
---

<footer class="site-footer font-mono">
  <span class="text-muted">© {year} Nate Schiffler</span>
  <div class="site-footer__links">
    <a href="mailto:hello@schiffn8design.com" class="site-footer__link">Email</a>
    <a href="https://linkedin.com/in/nateschiffler" class="site-footer__link" target="_blank" rel="noopener">LinkedIn</a>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    margin-top: auto;
  }

  .site-footer__links {
    display: flex;
    gap: 1.5rem;
  }

  .site-footer__link {
    transition: color var(--transition-base);
  }

  .site-footer__link:hover {
    color: var(--color-ink);
  }
</style>
