---
const navLinks = [
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="site-nav font-mono" aria-label="Site navigation">
  <a href="/" class="site-nav__logo" aria-label="Nate Schiffler — Home">
    NS
  </a>
  <ul class="site-nav__links" role="list">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class:list={['site-nav__link', { 'is-active': currentPath.startsWith(link.href) }]}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background-color: var(--color-paper);
    z-index: 100;
  }

  .site-nav__logo {
    font-weight: 500;
    color: var(--color-ink);
  }

  .site-nav__links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__link {
    color: var(--color-muted);
    transition: color var(--transition-base);
  }

  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--color-ink);
  }
</style>
