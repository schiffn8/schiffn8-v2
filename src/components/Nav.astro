---
const navLinks = [
  { label: 'Work',    href: '/work' },
  { label: 'About',   href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" aria-label="Site navigation">
  <a href="/" class="site-nav__logo font-mono" aria-label="Nate Schiffler — Home">
    NS
  </a>
  <ul class="site-nav__links font-mono" role="list">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class:list={['site-nav__link', { 'is-active': currentPath.startsWith(link.href) }]}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--gutter);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background-color: var(--paper);
    z-index: 100;
  }

  .site-nav__logo {
    font-weight: 500;
    color: var(--ink);
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .site-nav__logo:hover {
    opacity: 0.6;
  }

  .site-nav__links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
  }

  .site-nav__link {
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--ink);
  }
</style>
