---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, year, tags, summary, thumb } = project.data;
const href = `/work/${project.id}`;
const transitionName = `project-${project.id.replace(/[^a-z0-9]/gi, '-')}`;
---

<article class="project-card">
  <a href={href} class="project-card__link" aria-label={`View ${title} case study`}>
    <div class="project-card__thumb" transition:name={transitionName}>
      <Image
        src={thumb}
        alt={`${title} thumbnail`}
        width={800}
        height={600}
        class="project-card__img"
      />
    </div>
    <div class="project-card__info">
      <div class="project-card__meta font-mono">
        <span>{year}</span>
        <span aria-hidden="true">·</span>
        <span>{tags[0]}</span>
      </div>
      <h2 class="project-card__title font-display">{title}</h2>
      <p class="project-card__summary">{summary}</p>
    </div>
  </a>
</article>

<style>
  .project-card__link {
    display: block;
    text-decoration: none;
  }

  .project-card__thumb {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background-color: var(--line);
    margin-bottom: var(--space-6);
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .project-card__link:hover .project-card__img {
    transform: scale(1.03);
  }

  .project-card__meta {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .project-card__title {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-display);
    margin-bottom: var(--space-3);
  }

  .project-card__summary {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--muted);
    max-width: 40ch;
  }
</style>
