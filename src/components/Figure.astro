---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt?: string;
  caption?: string;
  wide?: boolean;
}

const { src, alt = '', caption, wide = false } = Astro.props;
const isMetadata = typeof src === 'object';
---

<figure class:list={['figure', { wide }]}>
  {isMetadata ? (
    <Image
      src={src as ImageMetadata}
      alt={alt}
      widths={[640, 960, 1280, 1920]}
      sizes="(max-width: 768px) 100vw, 70vw"
    />
  ) : (
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin: var(--space-12) 0;
  }

  .figure img,
  .figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
  }

  /* Breaks out of prose column for statement images */
  .figure.wide {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    max-width: var(--max-w-wide);
    margin-inline: auto;
    width: min(100vw, var(--max-w-wide));
    padding: 0 var(--gutter);
  }

  figcaption {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    margin-top: var(--space-3);
  }
</style>
